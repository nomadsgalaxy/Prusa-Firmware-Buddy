; Minimal Klipper-style PA test snippet.
; Covers every translation path klipper_to_marlin.py handles.

PRINT_START BED=60 EXTRUDER=215
G32
BED_MESH_CALIBRATE
BED_MESH_PROFILE LOAD=default

SET_VELOCITY_LIMIT VELOCITY=300 ACCEL=3000 SQUARE_CORNER_VELOCITY=5
SET_VELOCITY_LIMIT SQUARE_CORNER_VELOCITY=5

; --- PA sweep ---
SET_PRESSURE_ADVANCE ADVANCE=0.000 SMOOTH_TIME=0.040
G1 X10 Y20 Z0.2 F3000
G1 X40 Y20 E1.2 F600
SET_PRESSURE_ADVANCE ADVANCE=0.015
G1 X10 Y22 F3000
G1 X40 Y22 E1.2 F600
SET_PRESSURE_ADVANCE ADVANCE=0.030

; Some unrecognised Klipper commands we expect to warn on.
RESPOND MSG="hello"
SAVE_VARIABLE VARIABLE=x VALUE=1

PRINT_END
